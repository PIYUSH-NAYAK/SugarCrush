{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "react-native",
      "jest",
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "index.js",
    "App.tsx",
    "babel.config.js"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "sol",
    ".expo",
    "dist",
    "build"
  ]
}